# =============================================================================
# Paths listed below stay on your machine (or CI artifacts). They are NOT
# uploaded to GitHub when you push.
#
# This .gitignore file itself SHOULD be committed — that is normal and expected.
# =============================================================================

# Byte-compiled / cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/

# Virtual environments (local only — never commit)
.venv/
venv/
env/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Local media / test outputs
*.mkv
*.mp4
!sample/**

# PyInstaller (local only — publish via Actions artifacts if needed)
build/
dist/
*.spec

# Local draft for pasting into the GitHub Release description (Markdown).
# Never commit this — copy from RELEASE_BODY.md into the release UI instead.
RELEASE_BODY.md
